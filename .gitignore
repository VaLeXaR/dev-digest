node_modules/
dist/
# agent-runner ships as a JS GitHub Action — its bundled dist/ MUST be committed
# (GitHub runs action.yml `main: dist/index.js` as-is, with no build step).
!agent-runner/dist/
!agent-runner/dist/**
build/
.next/
out/
coverage/
*.tsbuildinfo
.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/

# emdash worktree config (local)
.emdash.json

# pr-self-review: per-developer local gate state
.pr-self-review.json

# Claude Code agent worktrees (local scratch space)
.claude/worktrees/

# Claude Code hook scratch space (engineering-insights change list, etc.)
.claude/tmp/
*/.claude/tmp/

data/
.claude/settings.local.json

# Windows/Git Bash quirk: `NUL` is a reserved device name; `2>/dev/null`-style
# redirects can materialize a literal `NUL` file at the repo root, which then
# pollutes `git status` and trips the engineering-insights stop gate every turn.
NUL
